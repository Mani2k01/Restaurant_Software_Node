<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Add Table</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #e5e7eb;
            --text: #111827;
            --muted: #6b7280;
            --green: #22c55e;
            --shadow: 0 6px 14px rgba(0, 0, 0, .08);
        }

        * {
            box-sizing: border-box
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* HEADER */

        .header {
            padding: 18px 26px;
            font-size: 20px;
            font-weight: 600;
            background: #ffffff;
            border-bottom: 1px solid var(--border);
        }

        /* FORM WRAPPER */

        .form-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
        }

        /* CARD */

        .form-card {
            background: var(--surface);
            box-shadow: var(--shadow);
            border-radius: 18px;
            padding: 28px;
            width: 340px;
        }

        /* ICON */

        .icon {
            text-align: center;
            font-size: 40px;
            color: #6b7280;
            margin-bottom: 10px;
        }

        /* TITLE */

        .form-title {
            text-align: center;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        /* INPUT */

        .input-group {
            margin-bottom: 16px;
        }

        .input-group label {
            display: block;
            font-size: 13px;
            margin-bottom: 6px;
            color: var(--muted);
        }

        .input-group input {
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-size: 14px;
        }

        .input-group input:focus {
            outline: none;
            border-color: var(--green);
        }

        /* BUTTON */

        .submit-btn {
            width: 100%;
            padding: 11px;
            border: none;
            border-radius: 10px;
            background: var(--green);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: .2s;
        }

        .submit-btn:hover {
            opacity: .9;
        }

        /* FOOTER */
        .footer {
            text-align: center;
            padding: 22px;
            font-size: 13px;
            color: var(--muted);
        }

    </style>
</head>

<body>

    <div class="header">🍽 Table Management</div>

    <div class="form-wrapper">

        <div class="form-card">

            <div class="icon">
                <i class="fa-solid fa-chair"></i>
            </div>

            <div class="form-title">Add New Table</div>

            <form id="addTableForm" method="post" action="/add_table">

                <div class="input-group">
                    <label>Table Number</label>
                    <input type="number" name="table_number" placeholder="Enter table number" required>
                </div>

                <div class="input-group">
                    <label>Number of Seats</label>
                    <input type="number" name="capacity" placeholder="Enter seat capacity" required>
                </div>

                <button class="submit-btn" type="submit">
                    <i class="fa-solid fa-plus"></i> Add Table
                </button>

            </form>

        </div>

    </div>

    <div class="footer">
        VEDSP Inventive Private Limited © 2026 Restaurant Management System
    </div>

</body>

</html>